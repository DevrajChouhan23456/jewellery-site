generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  username     String   @unique
  passwordHash String
  role         String   @default("ADMIN")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Logo {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  imageUrl  String
  createdAt DateTime @default(now())
}

model CuratedItem {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  section   String   @default("gender")
  title     String
  subtitle  String?
  image     String?
  link      String
  badge     String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HomepageSection {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  key                String   @unique
  eyebrow            String?
  title              String
  subtitle           String?
  description        String?
  ctaLabel           String?
  ctaHref            String?
  backgroundImageUrl String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Slider {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  imageUrl  String
  badge     String?
  title     String?
  subtitle  String?
  ctaLabel  String?
  ctaHref   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ShopPage {
  id              String            @id @default(auto()) @map("_id") @db.ObjectId
  slug            String            @unique
  title           String
  subtitle        String
  heroEyebrow     String?
  heroTitle       String
  heroDescription String
  heroImageUrl    String?
  heroCtaLabel    String            @default("Shop Now")
  heroCtaHref     String            @default("/shop/jewellery")
  resultCount     Int               @default(0)
  features        ShopPageFeature[] @relation("ShopPageToFeature")
  products        ShopPageProduct[] @relation("ShopPageToProduct")
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model ShopPageFeature {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  shopPageId String   @db.ObjectId
  title      String
  imageUrl   String
  href       String
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  shopPage   ShopPage @relation("ShopPageToFeature", fields: [shopPageId], references: [id])
}

model ShopPageProduct {
  id             String      @id @default(auto()) @map("_id") @db.ObjectId
  shopPageId     String      @db.ObjectId
  name           String
  price          Int
  imageUrl       String?
  images         String[]
  description    String?
  specifications Json?
  badge          String?
  lowStockText   String?
  order          Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  shopPage       ShopPage    @relation("ShopPageToProduct", fields: [shopPageId], references: [id])
  cartItems      CartItem[]
  orderItems     OrderItem[]
}

model Customer {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  name      String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  carts  Cart[]
  orders Order[]
}

model Cart {
  id         String     @id @default(auto()) @map("_id") @db.ObjectId
  customerId String?    @db.ObjectId
  sessionId  String?    @unique
  status     CartStatus @default(ACTIVE)
  expiresAt  DateTime?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  customer Customer?  @relation(fields: [customerId], references: [id])
  items    CartItem[]
  orders   Order[]

  @@index([customerId])
}

model CartItem {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  userId    String @db.ObjectId
  productId String @db.ObjectId

  quantity Int @default(1)

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  ShopPageProduct   ShopPageProduct? @relation(fields: [shopPageProductId], references: [id])
  shopPageProductId String?          @db.ObjectId
  Cart              Cart?            @relation(fields: [cartId], references: [id])
  cartId            String?          @db.ObjectId
}

model Order {
  id                String        @id @default(auto()) @map("_id") @db.ObjectId
  orderNumber       String        @unique @default(cuid())
  customerId        String?       @db.ObjectId
  cartId            String?       @db.ObjectId
  status            OrderStatus   @default(PENDING)
  paymentStatus     PaymentStatus @default(PENDING)
  currency          String        @default("INR")
  subtotalAmount    Int           @default(0)
  taxAmount         Int           @default(0)
  shippingAmount    Int           @default(0)
  discountAmount    Int           @default(0)
  totalAmount       Int           @default(0)
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?
  shippingAddress   Json?
  billingAddress    Json?
  metadata          Json?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  customer Customer?   @relation(fields: [customerId], references: [id])
  cart     Cart?       @relation(fields: [cartId], references: [id])
  items    OrderItem[]

  @@index([customerId])
}

model OrderItem {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  orderId   String   @db.ObjectId
  productId String   @db.ObjectId
  quantity  Int
  unitPrice Int
  lineTotal Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order   Order           @relation(fields: [orderId], references: [id])
  product ShopPageProduct @relation(fields: [productId], references: [id])

  @@unique([orderId, productId])
}

enum CartStatus {
  ACTIVE
  CHECKED_OUT
  ABANDONED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  PAID
  FAILED
  REFUNDED
}

model Product {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  slug        String     @unique
  category    String
  subCategory String? // 👈 ADD THIS
  price       Int
  images      String[]
  material    String
  type        String
  cartItems   CartItem[]
  wishlist    Wishlist[]
  createdAt   DateTime   @default(now())
}

model User {
  id    String  @id @default(auto()) @map("_id") @db.ObjectId
  phone String  @unique
  email String? @unique
  name  String?

  cartItems CartItem[]
  wishlist  Wishlist[]

  createdAt DateTime @default(now())
}

model OTP {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  otp        String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
}

model Wishlist {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  userId    String @db.ObjectId
  productId String @db.ObjectId

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())
}
