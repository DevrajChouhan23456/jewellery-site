generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
    url      = env("DATABASE_URL")

}

model AdminUser {
  id                     String    @id @default(auto()) @map("_id") @db.ObjectId
  username               String    @unique
  passwordHash           String
  role                   String    @default("ADMIN")
  twoFactorEnabled       Boolean?  @default(false)
  twoFactorSecret        String?
  twoFactorPendingSecret String?
  twoFactorUpdatedAt     DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
}

model Logo {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  imageUrl  String
  createdAt DateTime @default(now())
}

model CuratedItem {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  section   String   @default("gender")
  title     String
  subtitle  String?
  image     String?
  link      String
  badge     String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HomepageSection {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  key                String   @unique
  eyebrow            String?
  title              String
  subtitle           String?
  description        String?
  ctaLabel           String?
  ctaHref            String?
  backgroundImageUrl String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Slider {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  imageUrl  String
  badge     String?
  title     String?
  subtitle  String?
  ctaLabel  String?
  ctaHref   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ShopPage {
  id              String            @id @default(auto()) @map("_id") @db.ObjectId
  slug            String            @unique
  title           String
  subtitle        String
  category        String?
  heroEyebrow     String?
  heroTitle       String
  heroDescription String
  heroImageUrl    String?
  heroCtaLabel    String            @default("Shop Now")
  heroCtaHref     String            @default("/shop/jewellery")
  resultCount     Int               @default(0)
  features        ShopPageFeature[] @relation("ShopPageToFeature")
  products        ShopPageProduct[] @relation("ShopPageToProduct")
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model ShopPageFeature {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  shopPageId String   @db.ObjectId
  title      String
  imageUrl   String
  href       String
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  shopPage   ShopPage @relation("ShopPageToFeature", fields: [shopPageId], references: [id])
}

model ShopPageProduct {
  id             String      @id @default(auto()) @map("_id") @db.ObjectId
  slug           String      @unique
  shopPageId     String      @db.ObjectId
  name           String
  price          Int
  category       String
  material       String
  type           String
  imageUrl       String?
  images         String[]
  description    String?
  specifications Json?
  badge          String?
  lowStockText   String?
  order          Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  shopPage       ShopPage    @relation("ShopPageToProduct", fields: [shopPageId], references: [id])
  cartItems      CartItem[]
  orderItems     OrderItem[]
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String?  @unique
  name      String?
  phone     String?  @unique
  address   String?
  city      String?
  state     String?
  pincode   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  carts    Cart[]
  orders   Order[]
  wishlist Wishlist[]
  recoveries CartRecovery[]
  recommendations Recommendation[]

  @@index([createdAt])
}

model CartItem {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  cartId    String @db.ObjectId
  productId String @db.ObjectId

  quantity Int @default(1)

  cart    Cart            @relation(fields: [cartId], references: [id])
  product Product         @relation(fields: [productId], references: [id])

  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  ShopPageProduct   ShopPageProduct? @relation(fields: [shopPageProductId], references: [id])
  shopPageProductId String?          @db.ObjectId
}

model Order {
  id                String        @id @default(auto()) @map("_id") @db.ObjectId
  orderNumber       String        @unique @default(cuid())
  userId            String?       @db.ObjectId
  cartId            String?       @db.ObjectId
  status            OrderStatus   @default(PENDING)
  paymentStatus     PaymentStatus @default(PENDING)
  currency          String        @default("INR")
  subtotalAmount    Int           @default(0)
  taxAmount         Int           @default(0)
  shippingAmount    Int           @default(0)
  discountAmount    Int           @default(0)
  totalAmount       Int           @default(0)
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?
  shippingAddress   Json?
  billingAddress    Json?
  metadata          Json?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user User?   @relation(fields: [userId], references: [id])
  cart Cart?   @relation(fields: [cartId], references: [id])
  items OrderItem[]

  @@index([userId])
  @@index([paymentStatus])
  @@index([status])
  @@index([createdAt])
  @@index([userId, createdAt])
}

model OrderItem {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  orderId   String   @db.ObjectId
  productId String   @db.ObjectId
  quantity  Int
  unitPrice Int
  lineTotal Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order   Order           @relation(fields: [orderId], references: [id])
  product ShopPageProduct @relation(fields: [productId], references: [id])

  @@unique([orderId, productId])
}

enum CartStatus {
  ACTIVE
  CHECKED_OUT
  ABANDONED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  PAID
  FAILED
  REFUNDED
}

model Product {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  slug        String     @unique
  category    String
  subCategory String? // 👈 ADD THIS
  price       Int
  description String?   // AI-generated product description
  images      String[]
  material    String
  type        String
  size        String?    // 👈 ADD THIS for variant system
  stock       Int        @default(0) // Inventory count
  lowStockThreshold Int @default(10) // Alert when stock below this
  embeddings  Float[]  // OpenAI text-embedding-3-small embeddings
  cartItems   CartItem[]
  wishlist    Wishlist[]
  priceHistory PriceHistory[]
  recommendations Recommendation[]
  createdAt   DateTime   @default(now())

  @@index([name])
  @@index([category])
  @@index([material])
  @@index([type])
  @@index([size]) // 👈 ADD THIS
  @@index([price])
  @@index([createdAt])
  @@index([name, category])
  @@index([embeddings])
}

model Cart {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  userId    String?    @db.ObjectId
  sessionId String?    @unique
  status    CartStatus @default(ACTIVE)
  expiresAt DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user  User?   @relation(fields: [userId], references: [id])
  items CartItem[]
  orders Order[]
  recoveries CartRecovery[]

  @@index([userId])
  @@index([status])
  @@index([expiresAt])
  @@index([userId, status])
}

model OTP {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  otp        String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
}

model Wishlist {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  userId    String @db.ObjectId
  productId String @db.ObjectId

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())
}

// Automation Models
model AutomationSettings {
  id                    String   @id @default(auto()) @map("_id") @db.ObjectId
  key                   String   @unique
  value                 Json
  description           String?
  isEnabled             Boolean  @default(true)
  lastExecutedAt        DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model Alert {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  type        AlertType
  title       String
  message     String
  priority    AlertPriority @default(MEDIUM)
  isRead      Boolean    @default(false)
  metadata    Json?
  resolvedAt  DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model CartRecovery {
  id            String           @id @default(auto()) @map("_id") @db.ObjectId
  cartId        String           @db.ObjectId
  userId        String?          @db.ObjectId
  email         String
  recoveryToken String           @unique
  status        RecoveryStatus   @default(PENDING)
  sentAt        DateTime?
  clickedAt     DateTime?
  convertedAt   DateTime?
  expiresAt     DateTime
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  cart Cart? @relation(fields: [cartId], references: [id])
  user User? @relation(fields: [userId], references: [id])

  @@index([status])
  @@index([expiresAt])
  @@index([userId])
}

model PriceHistory {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  productId String   @db.ObjectId
  oldPrice  Int
  newPrice  Int
  reason    String   // e.g., "dynamic_pricing", "manual", "promotion"
  metadata  Json?    // additional context like demand score, competitor prices
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])
}

model Recommendation {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  userId          String?  @db.ObjectId
  sessionId       String?
  productId       String   @db.ObjectId
  recommendedFor  String   @db.ObjectId // product or user this is recommended for
  score           Float
  algorithm       String   // e.g., "collaborative", "content_based", "trending"
  context         String?  // e.g., "viewed_together", "similar_category"
  isClicked       Boolean  @default(false)
  isPurchased     Boolean  @default(false)
  expiresAt       DateTime?
  createdAt       DateTime @default(now())

  user    User?    @relation(fields: [userId], references: [id])
  product Product  @relation(fields: [productId], references: [id])
}

enum AlertType {
  INVENTORY_LOW
  SALES_DROP
  PRICE_CHANGE
  CART_ABANDONED
  ORDER_ISSUE
  SYSTEM_ERROR
}

enum AlertPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RecoveryStatus {
  PENDING
  SENT
  CLICKED
  CONVERTED
  EXPIRED
}
